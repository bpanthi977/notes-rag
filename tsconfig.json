{
    "include": ["src/**/*.ts", "src/*.ts"],
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "rootDir": "src/",
        "outDir": "build/",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": ["node"]
    }
}
